{
  "name": "trading-platform-root",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "frontend",
    "backend-node"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=frontend\" \"npm start --workspace=backend-node\" \"python3 backend-python/app.py\"",
    "start:frontend": "npm run dev --workspace=frontend",
    "start:backend-node": "npm start --workspace=backend-node",
    "start:backend-python": "python3 backend-python/app.py"
  },
  "dependencies": {
    "concurrently": "^9.2.1"
  }
}
